{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-c",
        "set -a && source .env && set +a && npx -y @modelcontextprotocol/server-github"
      ]
    },
    "slack": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-c",
        "set -a && source .env && set +a && npx -y @modelcontextprotocol/server-slack"
      ]
    }
  }
}
